{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "realtrigel/catalog-search",
	"version": "1.4.3",
	"title": "Поиск недвижимости",
	"category": "widgets",
	"icon": "search",
	"description": "Форма поиска, которая фильтрует блок каталога через URL-параметры.",
	"keywords": [ "поиск", "каталог", "недвижимость" ],
	"textdomain": "realtrigel-core",
	"editorScript": "file:./index.js",
	"viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css",
	"attributes": {
		"title": {
			"type": "string",
			"default": "Поиск недвижимости"
		},
		"buttonLabel": {
			"type": "string",
			"default": "Поиск"
		},
		"targetUrl": {
			"type": "string",
			"default": ""
		},
		"showResetButton": {
			"type": "boolean",
			"default": true
		},
		"searchPlaceholder": {
			"type": "string",
			"default": "Поиск помещения"
		},
		"moreFiltersLabel": {
			"type": "string",
			"default": "Больше фильтров"
		},
		"lessFiltersLabel": {
			"type": "string",
			"default": "Меньше фильтров"
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	}
}
